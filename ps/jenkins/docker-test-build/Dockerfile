# Percona Server 8.0 — test-build image
#
# Consumed by "hetzner-ps8.0-build-docker-test".
#
# Structurally this is a clone of the release image at
#     percona-docker/percona-server-8.0/Dockerfile (and .aarch64)
# so that the test image exercises the same layer topology, package set,
# telemetry wiring, config tweaks and runtime footprint as a released
# percona/percona-server:8.0 image.
#
# The one difference vs. the release flow: the RPMs produced by this
# Jenkins run are NOT published to a Percona yum repo before docker build
# runs. Instead, the pipeline stages them (plus createrepo_c metadata)
# into ./local-rpms/ and this Dockerfile pulls them from a file:// repo
# called ps-local. Everything else — percona-release for the telemetry
# repo, jemalloc/gflags from EPEL, the telemetry-agent fetch from
# GitHub — is identical to the release Dockerfile.
#
# Multi-arch: single Dockerfile. BuildKit populates TARGETARCH as
# amd64 / arm64 when the pipeline runs `docker build --platform=linux/<arch>`.
# That is mapped to the el9 arch names used in the EPEL URLs.
#
# Build context expected by stageDockerContext():
#     Dockerfile                       (this file)
#     ps-entry.sh                      (vendored copy of the release entrypoint)
#     telemetry-agent-supervisor.sh    (vendored from percona-docker)
#     local-rpms/*.rpm                 (el9, matching arch — staged by the pipeline)
#     local-rpms/repodata/             (generated by createrepo_c on the same node)

FROM redhat/ubi9-minimal

LABEL name="Percona Server" \
      release="8.0" \
      vendor="Percona" \
      summary="Percona Server 8.0 test build" \
      description="Percona Server 8.0 image built from locally-compiled RPMs for CI testing" \
      maintainer="Percona Development <info@percona.com>"

LABEL org.opencontainers.image.authors="info@percona.com"

# Populated automatically by BuildKit / buildx from --platform. Mapped
# below to the el9 arch names (x86_64 / aarch64) used by EPEL mirrors.
ARG TARGETARCH

# Version metadata. PS_VERSION is sed-overwritten by the pipeline so each
# run pins the exact version it just built, mirroring the sed pattern
# hetzner-ps8.0-docker-build uses against the release Dockerfile.
ENV PS_VERSION 8.0.43-34.1
ENV OS_VER el9
ENV FULL_PERCONA_VERSION "$PS_VERSION.$OS_VER"
ENV PS_REPO testing
ENV CALL_HOME_DOWNLOAD_SHA256 5e84d2f1a5d57f44c46e6a1f16794d649d3de09fe8021f0294bc321c89e51068
ENV KEY_RPM_DOWNLOAD_SHA256 fcf0eab4f05a1c0de6363ac4b707600a27a9d774e9b491059e59e6921b255a84
ENV CALL_HOME_VERSION 0.1

# Stays on during image build; the runtime setting is controlled by the
# entrypoint / container env.
ARG PERCONA_TELEMETRY_DISABLE=1

# UID/GID 1001 matches the upstream percona/percona-server image so that
# existing volumes remain usable when swapping between builds.
RUN set -ex; \
    groupadd -g 1001 mysql; \
    useradd -u 1001 -r -g 1001 -s /sbin/nologin \
        -m -c "Default Application User" mysql

# Locally-built Percona Server RPMs + createrepo_c metadata.
COPY local-rpms/ /tmp/local-rpms/

# percona-release setup (for GPG keys + telemetry repo) + ps-local file
# repo + EPEL jemalloc/gflags. Mirrors the release Dockerfile's first RUN
# block line-for-line except for the ps-80 repo URL, which is replaced
# with a file:// repo pointing at the rpms we just COPY'd.
RUN set -ex; \
    export GNUPGHOME="$(mktemp -d)"; \
    gpg --batch --keyserver keyserver.ubuntu.com --recv-keys 4D1BB29D63D98E422B2113B19334A25F8507EFA5 99DB70FAE1D7CE227FB6488205B555B38483C65D; \
    gpg --batch --export --armor 4D1BB29D63D98E422B2113B19334A25F8507EFA5 > ${GNUPGHOME}/PERCONA-PACKAGING-KEY; \
    gpg --batch --export --armor 99DB70FAE1D7CE227FB6488205B555B38483C65D > ${GNUPGHOME}/RPM-GPG-KEY-centosofficial; \
    rpmkeys --import ${GNUPGHOME}/PERCONA-PACKAGING-KEY ${GNUPGHOME}/RPM-GPG-KEY-centosofficial; \
    curl -Lf -o /tmp/percona-release.rpm https://repo.percona.com/yum/percona-release-latest.noarch.rpm; \
    rpmkeys --checksig /tmp/percona-release.rpm; \
    microdnf install -y findutils; \
    rpm -i /tmp/percona-release.rpm; \
    sed -i "s|x86_64|x86_64 aarch64|" /usr/bin/percona-release; \
    rm -rf "$GNUPGHOME" /tmp/percona-release.rpm; \
    rpm --import /etc/pki/rpm-gpg/PERCONA-PACKAGING-KEY; \
    percona-release disable all; \
    percona-release enable telemetry ${PS_REPO}; \
    printf '[ps-local]\nname=Percona Server 8.0 (local build)\nbaseurl=file:///tmp/local-rpms\nenabled=1\ngpgcheck=0\npriority=1\n' \
        > /etc/yum.repos.d/ps-local.repo; \
    rm -rf /tmp/percona-*; \
    curl -O https://dl.fedoraproject.org/pub/epel/RPM-GPG-KEY-EPEL-9; \
    echo "$KEY_RPM_DOWNLOAD_SHA256 RPM-GPG-KEY-EPEL-9" | sha256sum --strict --check; \
    rpm --import RPM-GPG-KEY-EPEL-9; \
    case "${TARGETARCH}" in \
        amd64) EPEL_ARCH=x86_64 ;; \
        arm64) EPEL_ARCH=aarch64 ;; \
        *) echo "unsupported TARGETARCH=${TARGETARCH}" >&2; exit 1 ;; \
    esac; \
    curl -Lf -o /tmp/jemalloc.rpm "https://rpmfind.net/linux/epel/9/Everything/${EPEL_ARCH}/Packages/j/jemalloc-5.2.1-2.el9.${EPEL_ARCH}.rpm"; \
    curl -Lf -o /tmp/gflags.rpm   "https://rpmfind.net/linux/epel/9/Everything/${EPEL_ARCH}/Packages/g/gflags-2.2.2-9.el9.${EPEL_ARCH}.rpm"; \
    rpmkeys --checksig /tmp/gflags.rpm /tmp/jemalloc.rpm; \
    rpm -i /tmp/jemalloc.rpm; \
    rpm -i /tmp/gflags.rpm; \
    rm -f /tmp/gflags.rpm /tmp/jemalloc.rpm

# Base tools, system package refresh, and Percona Server install from the
# ps-local file repo. Package list mirrors the release Dockerfiles; the
# only omission is percona-mysql-shell — it is a separate build that this
# pipeline does not produce, so trying to pull it from the ps-local repo
# would fail. percona-telemetry-agent comes from the telemetry repo
# (percona-release enable telemetry above) to stay aligned with
# Dockerfile.aarch64.
RUN set -ex; \
    rpm -e --nodeps tzdata; \
    microdnf -y install \
        hostname \
        tzdata \
        jemalloc \
        which \
        cracklib-dicts \
        tar \
        policycoreutils; \
    microdnf -y update \
        libnghttp2 \
        openssh \
        python3-setuptools-wheel \
        krb5-libs \
        pam \
        python3; \
    microdnf -y install \
        percona-server-server-${FULL_PERCONA_VERSION} \
        percona-server-devel-${FULL_PERCONA_VERSION} \
        percona-server-rocksdb-${FULL_PERCONA_VERSION} \
        percona-icu-data-files-${FULL_PERCONA_VERSION} \
        percona-telemetry-agent; \
    microdnf clean all; \
    rm -rf /var/cache/dnf /var/cache/yum /var/lib/mysql \
           /tmp/local-rpms /etc/yum.repos.d/ps-local.repo

# Directory layout + config tweaks — identical to the release Dockerfile.
RUN set -ex; \
    /usr/bin/install -m 0775 -o mysql -g root -d /var/lib/mysql /var/run/mysqld /docker-entrypoint-initdb.d; \
    find /etc/my.cnf /etc/my.cnf.d -name '*.cnf' -print0 \
        | xargs -0 grep -lZE '^(bind-address|log|user)' \
        | xargs -rt -0 sed -Ei 's/^(bind-address|log|user)/#&/'; \
    echo '!includedir /etc/my.cnf.d' >> /etc/my.cnf; \
    printf '[mysqld]\nhost_cache_size=0\nskip-name-resolve\n' > /etc/my.cnf.d/docker.cnf; \
    /usr/bin/install -m 0664 -o mysql -g root /dev/null /etc/sysconfig/mysql; \
    echo "LD_PRELOAD=/usr/lib64/libjemalloc.so.1" >> /etc/sysconfig/mysql; \
    echo "THP_SETTING=never" >> /etc/sysconfig/mysql; \
    chown -R mysql:root /etc/my.cnf /etc/my.cnf.d; \
    chmod -R ug+rwX /etc/my.cnf /etc/my.cnf.d

VOLUME ["/var/lib/mysql", "/var/log/mysql"]

# Telemetry agent call-home.sh + /usr/local/percona — identical fetch as
# the release Dockerfile so the test image runs the same telemetry
# supervisor layout.
RUN set -eux; \
    curl -fL "https://github.com/Percona-Lab/telemetry-agent/archive/refs/tags/phase-$CALL_HOME_VERSION.tar.gz" -o "phase-$CALL_HOME_VERSION.tar.gz"; \
    echo "$CALL_HOME_DOWNLOAD_SHA256 phase-$CALL_HOME_VERSION.tar.gz" | sha256sum --strict --check; \
    tar -xvf phase-$CALL_HOME_VERSION.tar.gz; \
    cp telemetry-agent-phase-$CALL_HOME_VERSION/call-home.sh .; \
    rm -rf telemetry-agent-phase-$CALL_HOME_VERSION phase-$CALL_HOME_VERSION.tar.gz; \
    chmod a+rx /call-home.sh; \
    mkdir -p /usr/local/percona; \
    chown mysql:mysql /usr/local/percona
ENV CALL_HOME_OPTIONAL_PARAMS=" -s ${OS_VER}"

COPY ps-entry.sh /docker-entrypoint.sh
COPY telemetry-agent-supervisor.sh /usr/bin/
RUN set -ex; \
    chown  mysql /usr/bin/telemetry-agent-supervisor.sh; \
    chown  mysql /usr/bin/percona-telemetry-agent; \
    chown  mysql /usr/local/percona/telemetry/history; \
    chmod ug+rwx /usr/bin/telemetry-agent-supervisor.sh; \
    chmod -R go+w /var/log/percona

ENV PERCONA_TELEMETRY_CHECK_INTERVAL=86400
ENV PERCONA_TELEMETRY_HISTORY_KEEP_INTERVAL=604800
ENV PERCONA_TELEMETRY_RESEND_INTERVAL=60
ENV PERCONA_TELEMETRY_URL=https://check.percona.com/v1/telemetry/GenericReport

ENTRYPOINT ["/docker-entrypoint.sh"]

USER mysql
EXPOSE 3306 33060
CMD ["mysqld"]
